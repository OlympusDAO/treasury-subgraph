{
  "name": "treasury-subgraph",
  "version": "1.0.0",
  "description": "Monorepo for the OlympusDAO treasury subgraph",
  "main": "index.js",
  "repository": "git@github.com:0xJem/federated-subgraph.git",
  "author": "Jem <0x0xjem@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:release": "dotenv -e .env.prod -- turbo run build:release --force",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "docker:build:server": "docker build -f apps/server/Dockerfile -t treasury-subgraph/server:local .",
    "docker:tag:scan:server": "docker tag treasury-subgraph/server:local treasury-subgraph/server:scan",
    "server:start": "cd apps/server && dotenv -e ../../.env -- pnpm start",
    "changelog": "cd apps/client && pnpm changelog",
    "depcheck": "syncpack",
    "depcheck:fix": "syncpack fix-mismatches",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "test:local": "WG_PUBLIC_NODE_URL=http://localhost:9991/ dotenv -- turbo run test",
    "preinstall": "npx only-allow@1.2.2 pnpm"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "dotenv-cli": "^11.0.0",
    "syncpack": "^13.0.4",
    "turbo": "^1.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24",
    "pnpm": "10.33.0",
    "npm": "use-pnpm",
    "yarn": "use-pnpm",
    "bun": "use-pnpm"
  }
}
