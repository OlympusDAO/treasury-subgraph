{
  "name": "treasury-subgraph",
  "version": "1.0.0",
  "description": "Monorepo for the OlympusDAO treasury subgraph",
  "main": "index.js",
  "repository": "git@github.com:0xJem/federated-subgraph.git",
  "author": "Jem <0x0xjem@gmail.com>",
  "license": "MIT",
  "private": true,
  "resolutions": {
    "graphql": "^16.8.0",
    "js-yaml": "^4.1.1"
  },
  "scripts": {
    "build": "turbo run build",
    "build:release": "dotenv -e .env.prod -- turbo run build:release --force",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "server:start": "cd apps/server && dotenv -e ../../.env -- yarn start",
    "changelog": "cd apps/client && yarn changelog",
    "depcheck": "syncpack",
    "depcheck:fix": "syncpack fix-mismatches",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "test:local": "WG_PUBLIC_NODE_URL=http://localhost:9991/ dotenv -- turbo run test",
    "preinstall": "npx only-allow pnpm"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "dotenv-cli": "^11.0.0",
    "syncpack": "^13.0.4",
    "turbo": "^1.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "pnpm": "10.33.0",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "pnpm": {
    "overrides": {
      "@types/express": "4.17.14",
      "@types/express-serve-static-core": "4.17.31",
      "brace-expansion": ">=2.0.3",
      "effect": ">=3.20.0",
      "minimatch": ">=9.0.7",
      "picomatch": ">=2.3.2",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2",
      "effect@<3.20.0": ">=3.20.0",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "picomatch@<2.3.2": ">=2.3.2"
    }
  }
}
