{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": ["dist"],
      "env": ["WG_PUBLIC_NODE_URL", "ARBITRUM_SUBGRAPH_API_KEY"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "cache": false
    },
    "lint": {},
    "lint:check": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^test"],
      "env": ["ARBITRUM_SUBGRAPH_API_KEY"]
    },
    "test:ci": {
      "dependsOn": ["^test:ci"],
      "env": ["ARBITRUM_SUBGRAPH_API_KEY"]
    },
    "build:release": {
      "dependsOn": ["^build:release"],
      "cache": false,
      "dotEnv": [".env.prod"]
    }
  }
}
